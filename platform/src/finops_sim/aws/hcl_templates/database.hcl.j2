{# ──────────────────────────────────────────────────────────────────────────
   Database resource templates: aws_db_instance, aws_db_proxy,
   aws_elasticache_replication_group, aws_dynamodb_table,
   aws_redshift_cluster, aws_ec2_reserved_instances
   ────────────────────────────────────────────────────────────────────────── #}

{% macro aws_db_instance(r) %}
resource "aws_db_instance" "{{ r.resource_name }}" {
  identifier     = "{{ r.config.identifier | default(r.resource_name) }}"
  engine         = "{{ r.config.engine | default('mysql') }}"
  engine_version = "{{ r.config.engine_version | default('8.0') }}"
  instance_class = "{{ r.config.instance_class | default('db.t3.medium') }}"

  allocated_storage = {{ r.config.allocated_storage | default(r.config.db_size_gb | default(100)) }}
  storage_type      = "{{ r.config.storage_type | default('gp3') }}"

  multi_az = {{ r.config.multi_az | default(false) | lower }}

  {% if r.config.role is defined and r.config.role == 'read_replica' %}
  replicate_source_db = aws_db_instance.{{ r.config.source_db | default('primary') }}.identifier
  {% endif %}

  backup_retention_period = {{ r.config.backup_retention_period | default(7) }}

  skip_final_snapshot = {{ r.config.skip_final_snapshot | default(false) | lower }}

  tags = {
    Name        = "{{ r.resource_name }}"
    {% if r.config.environment is defined %}
    Environment = "{{ r.config.environment }}"
    {% endif %}
    {% if r.config.role is defined %}
    Role        = "{{ r.config.role }}"
    {% endif %}
    {% if r.config.tags is defined %}
    {% for key, value in r.config.tags.items() %}
    {{ key }} = "{{ value }}"
    {% endfor %}
    {% endif %}
  }
}
{% endmacro %}


{% macro aws_db_proxy(r) %}
resource "aws_db_proxy" "{{ r.resource_name }}" {
  name                   = "{{ r.config.proxy_name | default(r.resource_name) }}"
  debug_logging          = {{ r.config.debug_logging | default(false) | lower }}
  engine_family          = "{{ r.config.engine_family | default('MYSQL') }}"
  idle_client_timeout    = {{ r.config.idle_timeout | default(1800) }}
  require_tls            = {{ r.config.require_tls | default(true) | lower }}
  role_arn               = aws_iam_role.{{ r.resource_name }}_role.arn
  vpc_security_group_ids = [aws_security_group.{{ r.resource_name }}_sg.id]
  vpc_subnet_ids         = var.private_subnet_ids

  auth {
    auth_scheme = "SECRETS"
    iam_auth    = "{{ r.config.iam_auth | default('DISABLED') }}"
    secret_arn  = aws_secretsmanager_secret.{{ r.resource_name }}_secret.arn
  }

  tags = {
    Name = "{{ r.resource_name }}"
  }
}

resource "aws_db_proxy_default_target_group" "{{ r.resource_name }}" {
  db_proxy_name = aws_db_proxy.{{ r.resource_name }}.name

  connection_pool_config {
    max_connections_percent      = {{ r.config.max_connections_percent | default(80) }}
    max_idle_connections_percent = {{ r.config.max_idle_connections_percent | default(50) }}
  }
}

resource "aws_db_proxy_target" "{{ r.resource_name }}" {
  db_proxy_name          = aws_db_proxy.{{ r.resource_name }}.name
  target_group_name      = aws_db_proxy_default_target_group.{{ r.resource_name }}.name
  db_instance_identifier = aws_db_instance.{{ r.config.target_db | default('primary') }}.identifier
}
{% endmacro %}


{% macro aws_elasticache_replication_group(r) %}
resource "aws_elasticache_replication_group" "{{ r.resource_name }}" {
  replication_group_id = "{{ r.resource_name }}"
  description          = "{{ r.config.description | default('Redis replication group') }}"

  node_type            = "{{ r.config.node_type | default('cache.t3.medium') }}"
  num_cache_clusters   = {{ r.config.num_cache_clusters | default(2) }}
  engine               = "{{ r.config.engine | default('redis') }}"
  engine_version       = "{{ r.config.engine_version | default('7.0') }}"

  automatic_failover_enabled = {{ r.config.automatic_failover | default(true) | lower }}

  port = {{ r.config.port | default(6379) }}

  subnet_group_name  = aws_elasticache_subnet_group.{{ r.resource_name }}.name
  security_group_ids = [aws_security_group.{{ r.resource_name }}_sg.id]

  tags = {
    Name = "{{ r.resource_name }}"
  }
}

resource "aws_elasticache_subnet_group" "{{ r.resource_name }}" {
  name       = "{{ r.resource_name }}-subnet-group"
  subnet_ids = var.private_subnet_ids
}
{% endmacro %}


{% macro aws_dynamodb_table(r) %}
resource "aws_dynamodb_table" "{{ r.resource_name }}" {
  name         = "{{ r.resource_name }}"
  billing_mode = "{{ r.config.billing_mode | default('PAY_PER_REQUEST') }}"

  hash_key  = "{{ r.config.hash_key | default('id') }}"
  {% if r.config.range_key is defined %}
  range_key = "{{ r.config.range_key }}"
  {% endif %}

  attribute {
    name = "{{ r.config.hash_key | default('id') }}"
    type = "S"
  }

  {% if r.config.range_key is defined %}
  attribute {
    name = "{{ r.config.range_key }}"
    type = "S"
  }
  {% endif %}

  {% if r.config.billing_mode | default('PAY_PER_REQUEST') == 'PROVISIONED' %}
  read_capacity  = {{ r.config.read_capacity_units | default(5) }}
  write_capacity = {{ r.config.write_capacity_units | default(5) }}

  {% endif %}

  point_in_time_recovery {
    enabled = {{ r.config.point_in_time_recovery | default(true) | lower }}
  }

  tags = {
    Name = "{{ r.resource_name }}"
  }
}
{% endmacro %}


{% macro aws_redshift_cluster(r) %}
resource "aws_redshift_cluster" "{{ r.resource_name }}" {
  cluster_identifier = "{{ r.config.cluster_identifier | default(r.resource_name) }}"
  database_name      = "{{ r.config.database_name | default('analytics') }}"
  master_username    = "{{ r.config.master_username | default('admin') }}"
  master_password    = var.redshift_master_password
  node_type          = "{{ r.config.node_type | default('ra3.xlplus') }}"
  number_of_nodes    = {{ r.config.number_of_nodes | default(2) }}

  encrypted = {{ r.config.encrypted | default(true) | lower }}

  skip_final_snapshot = {{ r.config.skip_final_snapshot | default(false) | lower }}

  tags = {
    Name     = "{{ r.resource_name }}"
    Schedule = "{{ r.config.schedule | default('always-on') }}"
  }
}

{% if r.config.pause_resume_schedule is defined %}
# Redshift scheduled actions for pause/resume
resource "aws_redshift_scheduled_action" "{{ r.resource_name }}_pause" {
  name     = "{{ r.resource_name }}-pause"
  schedule = "{{ r.config.pause_resume_schedule.split(' / ')[1] | default('cron(0 18 ? * MON-FRI *)') }}"
  iam_role = aws_iam_role.{{ r.resource_name }}_scheduler_role.arn

  target_action {
    pause_cluster {
      cluster_identifier = aws_redshift_cluster.{{ r.resource_name }}.cluster_identifier
    }
  }
}

resource "aws_redshift_scheduled_action" "{{ r.resource_name }}_resume" {
  name     = "{{ r.resource_name }}-resume"
  schedule = "{{ r.config.pause_resume_schedule.split(' / ')[0] | default('cron(0 9 ? * MON-FRI *)') }}"
  iam_role = aws_iam_role.{{ r.resource_name }}_scheduler_role.arn

  target_action {
    resume_cluster {
      cluster_identifier = aws_redshift_cluster.{{ r.resource_name }}.cluster_identifier
    }
  }
}
{% endif %}
{% endmacro %}


{% macro aws_ec2_reserved_instances(r) %}
# ──────────────────────────────────────────────────────────────────────────
# Reserved Instance Commitment: {{ r.resource_name }}
# ──────────────────────────────────────────────────────────────────────────
# Reserved Instances are purchase commitments, not Terraform-managed
# resources. This block documents the RI for visibility in the IaC codebase.
#
# Instance Type:  {{ r.config.instance_type | default('unknown') }}
# Offering Type:  {{ r.config.offering_type | default('No Upfront') }}
# Term:           {{ r.config.term | default('1yr') }}
# State:          {{ r.config.state | default('active') }}
# Utilization:    {{ r.config.utilization | default('unknown') }}%
# Count:          {{ r.config.count | default(1) }}
#
# To query RI status via AWS CLI:
#   aws ec2 describe-reserved-instances --filters Name=state,Values=active

data "aws_ec2_reserved_instances_offerings" "{{ r.resource_name }}" {
  instance_type     = "{{ r.config.instance_type | default('m5.xlarge') }}"
  offering_type     = "{{ r.config.offering_type | default('No Upfront') }}"
  product_description = "Linux/UNIX"

  filter {
    name   = "duration"
    values = ["{{ '31536000' if r.config.term | default('1yr') == '1yr' else '94608000' }}"]
  }
}
{% endmacro %}
